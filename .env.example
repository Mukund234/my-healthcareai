# Environment Configuration

# Database (primary relational store)
DATABASE_URL=sqlite:///./health_predictor.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/health_predictor

# MongoDB (optional, for chat sessions, logs, telemetry)
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=healthcare_ai

# OpenAI API (Optional - leave empty to use rule-based explanations)
OPENAI_API_KEY=

# LLM Model (if using OpenAI)
LLM_MODEL=gpt-3.5-turbo

# Security
SECRET_KEY=your-secret-key-change-in-production-use-random-string

# Debug Mode
DEBUG=True

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
